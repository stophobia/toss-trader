# Toss Trader - optional default credentials
#
# If both of the variables below are set, the UI will offer a "기본 키로 시작"
# shortcut and you can skip entering your Toss Open API credentials every time.
# Leave them blank (or delete this file) to keep the original "enter every time"
# behavior.
#
# SECURITY:
#   - Never commit your real .env.local. The repo's .gitignore already
#     excludes .env* files, but be careful.
#   - On macOS/Linux, run `chmod 600 .env.local` after creating it so only
#     your user account can read it.
#   - These credentials grant LIVE ORDERING access to your Toss account.
#     Treat them like passwords.
#   - If you accidentally expose them (chat, screen share, commit, log),
#     rotate the keys immediately at WTS > 설정 > Open API.

# Toss Open API key
TOSSINVEST_DEFAULT_API_KEY=

# Toss Open API secret
TOSSINVEST_DEFAULT_SECRET_KEY=
